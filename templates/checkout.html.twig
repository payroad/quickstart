<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Payroad Quickstart</title>
    {% if stripe_publishable_key %}
    <script src="https://js.stripe.com/v3/"></script>
    {% endif %}
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, sans-serif; background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { background: #fff; border-radius: 12px; padding: 2rem; width: 100%; max-width: 420px; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
        h1 { font-size: 1.2rem; font-weight: 600; margin-bottom: 1.5rem; color: #111; }
        label { display: block; font-size: .85rem; color: #555; margin-bottom: .35rem; }
        input, select { width: 100%; padding: .6rem .8rem; border: 1px solid #ddd; border-radius: 8px; font-size: 1rem; margin-bottom: 1rem; }
        button { width: 100%; padding: .75rem; background: #0070f3; color: #fff; border: none; border-radius: 8px; font-size: 1rem; font-weight: 500; cursor: pointer; }
        button:disabled { opacity: .6; cursor: not-allowed; }
        #stripe-element { border: 1px solid #ddd; border-radius: 8px; padding: .75rem; margin-bottom: 1rem; }
        #message { margin-top: 1rem; padding: .75rem; border-radius: 8px; font-size: .9rem; display: none; }
        #message.success { background: #f0fdf4; color: #166534; display: block; }
        #message.error   { background: #fef2f2; color: #991b1b; display: block; }
    </style>
</head>
<body>
<div class="card">
    <h1>Payroad Quickstart</h1>

    <label>Amount (USD)</label>
    <input id="amount" type="number" min="1" step="0.01" value="19.99">

    <label>Provider</label>
    <select id="provider">
        <option value="mock_card">Mock card (instant)</option>
        <option value="mock_card_async">Mock async (webhook demo)</option>
        {% if stripe_publishable_key %}
        <option value="stripe">Stripe (real)</option>
        {% endif %}
    </select>

    <div id="stripe-element" style="display:none"></div>

    <button id="pay-btn">Pay</button>
    <button id="webhook-btn" style="display:none; margin-top:.75rem; background:#6b7280">Simulate webhook →</button>
    <div id="message"></div>
</div>

<script>
    {% if stripe_publishable_key %}
    const STRIPE_KEY = '{{ stripe_publishable_key }}';
    const stripe = Stripe(STRIPE_KEY);
    let stripeElements = null;
    let stripeEl = null;
    {% endif %}

    const providerSelect = document.getElementById('provider');
    const stripeDiv      = document.getElementById('stripe-element');

    providerSelect.addEventListener('change', () => {
        const isStripe = providerSelect.value === 'stripe';
        stripeDiv.style.display = isStripe ? 'block' : 'none';
        {% if stripe_publishable_key %}
        if (isStripe && !stripeElements) initStripeElement();
        {% endif %}
    });

    {% if stripe_publishable_key %}
    function initStripeElement() {
        stripeElements = stripe.elements();
        stripeEl = stripeElements.create('card');
        stripeEl.mount('#stripe-element');
    }
    {% endif %}

    const webhookBtn = document.getElementById('webhook-btn');
    let currentPaymentId = null;

    document.getElementById('pay-btn').addEventListener('click', async () => {
        const btn      = document.getElementById('pay-btn');
        const msg      = document.getElementById('message');
        const amount   = document.getElementById('amount').value;
        const provider = providerSelect.value;

        btn.disabled = true;
        msg.className = '';
        webhookBtn.style.display = 'none';
        currentPaymentId = null;

        try {
            // Step 1: create payment + initiate attempt
            const res = await fetch('/pay', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount, currency: 'USD', provider }),
            });
            const data = await res.json();

            if (!res.ok) throw new Error(data.error ?? 'Request failed');

            // Step 2: if Stripe — confirm via Stripe.js
            {% if stripe_publishable_key %}
            if (provider === 'stripe' && data.clientToken) {
                const { error } = await stripe.confirmCardPayment(data.clientToken, {
                    payment_method: { card: stripeEl },
                });
                if (error) throw new Error(error.message);
            }
            {% endif %}

            // Step 3: poll for final status (quick check first)
            const quickStatus = await pollStatus(data.paymentId, 2);
            if (quickStatus === 'processing') {
                // Async provider — show webhook button, let user trigger completion
                currentPaymentId = data.paymentId;
                msg.textContent = `Payment ${data.paymentId} is processing — click "Simulate webhook" to complete it.`;
                msg.className = 'error';
                msg.style.background = '#fffbeb';
                msg.style.color = '#92400e';
                webhookBtn.style.display = 'block';
            } else {
                msg.textContent = `Payment ${quickStatus} ✓ (ID: ${data.paymentId})`;
                msg.className = quickStatus === 'succeeded' ? 'success' : 'error';
            }

        } catch (e) {
            msg.textContent = e.message;
            msg.className = 'error';
        } finally {
            btn.disabled = false;
        }
    });

    webhookBtn.addEventListener('click', async () => {
        if (!currentPaymentId) return;
        webhookBtn.disabled = true;

        try {
            const res = await fetch(`/dev/webhook/${currentPaymentId}`, { method: 'POST' });
            if (!res.ok) {
                const err = await res.json();
                throw new Error(err.error ?? 'Webhook failed');
            }

            const status = await pollStatus(currentPaymentId);
            const msg = document.getElementById('message');
            msg.style.background = '';
            msg.style.color = '';
            msg.textContent = `Payment ${status} ✓ (ID: ${currentPaymentId})`;
            msg.className = status === 'succeeded' ? 'success' : 'error';
            webhookBtn.style.display = 'none';
            currentPaymentId = null;
        } catch (e) {
            const msg = document.getElementById('message');
            msg.textContent = e.message;
            msg.className = 'error';
        } finally {
            webhookBtn.disabled = false;
        }
    });

    async function pollStatus(paymentId, retries = 8) {
        for (let i = 0; i < retries; i++) {
            const r    = await fetch(`/pay/${paymentId}/status`);
            const data = await r.json();
            if (['succeeded', 'failed', 'canceled', 'expired'].includes(data.status)) {
                return data.status;
            }
            await new Promise(r => setTimeout(r, 500));
        }
        return 'processing';
    }
</script>
</body>
</html>
