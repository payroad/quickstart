{
    "name": "payroad/quickstart",
    "description": "Payroad quickstart — minimal Symfony app to accept payments in minutes",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "payroad/internal-card-provider": "@dev",
        "payroad/payroad-core": "@dev",
        "payroad/stripe-provider": "@dev",
        "payroad/symfony-bridge": "@dev",
        "symfony/framework-bundle": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/string": "^7.4",
        "symfony/twig-bundle": "^7.2",
        "symfony/yaml": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true
        }
    },
    "repositories": [
        { "type": "vcs", "url": "https://github.com/payroad/payroad-core" },
        { "type": "vcs", "url": "https://github.com/payroad/stripe-provider" },
        { "type": "vcs", "url": "https://github.com/payroad/internal-card-provider" },
        { "type": "vcs", "url": "https://github.com/payroad/symfony-bridge" }
    ]
}
